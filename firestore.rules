rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidContactSubmission(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'createdAt', 'userId'])
        && data.keys().size() == 5
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.email is string && data.email.size() > 0 && data.email.size() <= 200
        && data.message is string && data.message.size() > 0 && data.message.size() <= 5000
        && data.createdAt is timestamp
        && data.userId == request.auth.uid;
    }

    match /artifacts/{appId}/public/{data}/submissions/{submissionId} {
      allow read, delete: if isSignedIn(); // As requested by user's simple password logic
      
      allow create: if isSignedIn()
        && isValidId(appId)
        && isValidId(data)
        && isValidId(submissionId)
        && isValidContactSubmission(incoming())
        && incoming().createdAt == request.time;
    }
  }
}
